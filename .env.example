APP_ENV=development
JWT_SECRET=change-me
POSTGRES_DB=bizard_leads
POSTGRES_USER=bizard
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://bizard:change-me@postgres:5432/bizard_leads
REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TTL_SECONDS=120
CACHE_TRENDS_TTL_SECONDS=900
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_RATE=1.0
RATE_LIMIT_DEFAULT=60/minute
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_WEBHOOK_SHARED_HEADER_NAME=X-Bizard-Webhook-Secret
CHATWOOT_API_KEY=
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USERNAME=
MAILTRAP_PASSWORD=
# n8n removed — all workflows now use LangGraph agents
SOCIAL_TRENDS_WEBHOOK_PATH=social/trends
SOCIAL_PUBLISH_WEBHOOK_PATH=social/publish
SOCIAL_ANALYTICS_WEBHOOK_PATH=social/analytics
CHATWOOT_BASE_URL=https://app.chatwoot.com/api/v1
EMAIL_FROM=noreply@bizardleads.local
REPORT_RECIPIENT_EMAIL=founder@bizardleads.local
SOCIAL_DEFAULT_TOPIC=small business marketing
MAPS_SCRAPE_DELAY_SECONDS=2.0
WEBSITE_PARSE_DELAY_SECONDS=1.0
LINKEDIN_SCRAPE_DELAY_SECONDS=5.0
SMTP_VERIFY_PER_MINUTE=10
LEAD_PIPELINE_BATCH_SIZE=20
TASKS_ALWAYS_EAGER=false

# LangGraph / LLM
GROQ_API_KEY=
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
LLM_CACHE_TTL_SECONDS=86400
LLM_MAX_TOKENS_PER_NODE=2000

# Tavily (intent signals)
TAVILY_API_KEY=

# Qdrant (vector DB)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_LEADS=leads_embeddings
QDRANT_COLLECTION_SUPPORT_KB=support_knowledge_base
QDRANT_COLLECTION_ICP=user_icp_profiles

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Agent tuning
AGENT_MAX_RETRIES=3
AGENT_RETRY_BASE_DELAY=1.0
AGENT_CIRCUIT_BREAKER_THRESHOLD=5
AGENT_FALLBACK_ENABLED=true
TRIANGULATION_MIN_SOURCES=2
LEAD_SCORE_THRESHOLD=40
